{
    "name": "rsb-website",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "engines": {
        "node": ">=22.13.0"
    },
    "scripts": {
        "dev": "vite",
        "prebuild": "node scripts/generate-static-metadata.mjs",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "test": "vitest run",
        "install:post-commit-hook": "sh scripts/install-post-commit-hook.sh",
        "post-commit:reload": "sh scripts/git-hooks/post-commit"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^5.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "typescript": "^5.8.0",
        "vite": "^7.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^9.0.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.0",
        "globals": "^16.0.0",
        "typescript-eslint": "^8.0.0",
        "vitest": "^4.1.10"
    }
}
